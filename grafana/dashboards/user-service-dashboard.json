{
  "dashboard": {
    "title": "InnoUserService Monitoring Dashboard",
    "tags": ["user-service", "microservices"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "User Operations Rate",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(user_created_total{application=\"inno-user-service\"}[5m])",
            "legendFormat": "Users Created/sec",
            "refId": "A"
          },
          {
            "expr": "rate(user_updated_total{application=\"inno-user-service\"}[5m])",
            "legendFormat": "Users Updated/sec",
            "refId": "B"
          },
          {
            "expr": "rate(user_deleted_total{application=\"inno-user-service\"}[5m])",
            "legendFormat": "Users Deleted/sec",
            "refId": "C"
          }
        ],
        "yaxes": [
          {
            "label": "Operations/sec",
            "format": "short"
          }
        ]
      },
      {
        "id": 2,
        "title": "HTTP Request Rate",
        "type": "graph",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{application=\"inno-user-service\"}[5m])",
            "legendFormat": "{{method}} {{uri}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "Database Query Duration (95th percentile)",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(database_query_time_seconds_bucket{application=\"inno-user-service\"}[5m]))",
            "legendFormat": "{{operation}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "label": "Duration (seconds)",
            "format": "s"
          }
        ]
      },
      {
        "id": 4,
        "title": "JVM Memory Usage",
        "type": "graph",
        "gridPos": {
          "x": 12,
          "y": 8,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{application=\"inno-user-service\",area=\"heap\"}",
            "legendFormat": "Heap Used",
            "refId": "A"
          },
          {
            "expr": "jvm_memory_max_bytes{application=\"inno-user-service\",area=\"heap\"}",
            "legendFormat": "Heap Max",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "Memory",
            "format": "bytes"
          }
        ]
      },
      {
        "id": 5,
        "title": "Error Rate",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 16,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(operation_failure_total{application=\"inno-user-service\"}[5m])",
            "legendFormat": "{{operation}} - {{reason}}",
            "refId": "A"
          }
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {
                "params": [0.1],
                "type": "gt"
              },
              "operator": {
                "type": "and"
              },
              "query": {
                "params": ["A", "5m", "now"]
              },
              "reducer": {
                "params": [],
                "type": "avg"
              },
              "type": "query"
            }
          ],
          "name": "High Error Rate Alert"
        }
      },
      {
        "id": 6,
        "title": "Active Threads",
        "type": "graph",
        "gridPos": {
          "x": 12,
          "y": 16,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "jvm_threads_live_threads{application=\"inno-user-service\"}",
            "legendFormat": "Live Threads",
            "refId": "A"
          },
          {
            "expr": "jvm_threads_daemon_threads{application=\"inno-user-service\"}",
            "legendFormat": "Daemon Threads",
            "refId": "B"
          }
        ]
      },
      {
        "id": 7,
        "title": "Card Info Operations",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 24,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "cardinfo_created_total{application=\"inno-user-service\"}",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        }
      },
      {
        "id": 8,
        "title": "Auth Validation Avg Time",
        "type": "stat",
        "gridPos": {
          "x": 6,
          "y": 24,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "rate(auth_validation_time_seconds_sum{application=\"inno-user-service\"}[5m]) / rate(auth_validation_time_seconds_count{application=\"inno-user-service\"}[5m])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 9,
        "title": "Health Status",
        "type": "stat",
        "gridPos": {
          "x": 12,
          "y": 24,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "up{job=\"user-service\"}",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "options": {
                  "0": {
                    "color": "red",
                    "text": "DOWN"
                  },
                  "1": {
                    "color": "green",
                    "text": "UP"
                  }
                },
                "type": "value"
              }
            ]
          }
        }
      }
    ],
    "refresh": "10s",
    "schemaVersion": 27,
    "version": 1
  }
}
